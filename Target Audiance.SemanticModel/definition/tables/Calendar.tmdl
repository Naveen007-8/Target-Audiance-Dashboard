	column Weektype
		lineageTag: f285cce9-fc6a-4f46-b884-4c9678a92527
		summarizeBy: none
		isNameInferred
		sourceColumn: [Weektype]

		annotation SummarizationSetBy = Automatic

	partition Calendar = calculated
		mode: import
		source =
				
				ADDCOLUMNS(
				    CALENDARAUTO(),
				    "Year", YEAR([Date]),
				    "Month", FORMAT([Date],"mmm"),
				    "Monthnum", MONTH([Date]),
				    "Weekday", FORMAT([Date],"ddd"),
				    "Weeknum", WEEKDAY([Date]),
				    "QTR", "Q-" & FORMAT([Date],"Q"),
				    "Weektype", IF(WEEKDAY([Date])=1 || WEEKDAY([Date])=7,"Weekend","Weekday")
				)

	annotation PBI_Id = 875429c919a249fd864bf7a06900f428

